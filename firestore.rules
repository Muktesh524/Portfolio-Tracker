rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Stocks collection — read-only for authenticated users
    match /stocks/{stockId} {
      allow read: if request.auth != null;
      allow write: if false; // admin-only via seed script
    }

    // Mutual Funds collection — read-only for authenticated users
    match /mutual_funds/{fundId} {
      allow read: if request.auth != null;
      allow write: if false; // admin-only via seed script
    }

    // Per-user holdings — each user can only read/write their own
    match /users/{userId}/holdings/{holdingId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Per-user profile document
    match /users/{userId}/profile {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
